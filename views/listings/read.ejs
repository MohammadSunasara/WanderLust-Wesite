<% layout ("/layouts/boilerplate.ejs") %>

<div class="row">
  <div class="col-8 offset-2 mt-2">
    <h3><%= listings.title %></h3>
  </div>
  <div class="card col-8 offset-2 listing-card">
    <img src="<%= listings.image %>" class="card-img-top m-0" alt="Listing_image">
    <div class="card-body">
      <p class="card-text mt-3 mb-3">
        <b>Owned By :</b> <%= listings.owner.username %> <br>
        <b>Description:</b> <%= listings.description %> <br>
        <b>Price:</b> &#8377 <%= listings.price %> / night <br>
        <b>Location:</b> <%= listings.location %> <br>
        <b>Country:</b> <%= listings.country %> <br>
      </p>
      <% if (currUser && currUser._id.equals(listings.owner._id)) { %>
        <div class="btns">
          <a href="/listings/<%= listings.id %>/edit" class="btn btn-primary mb-2 mt-3 edit">Edit</a>
          <form action="/listings/<%= listings.id %>?_method=DELETE" method="POST">
            <button class="btn btn-primary offset-4 mb-2 mt-3">Delete</button>
          </form>
        </div>
      <% } %>
    </div>
  </div>
  
  <div class="col-8 offset-3">
    <hr>
    <h4>Leave a Review</h4>
    <form action="/listings/<%= listings.id %>/reviews" method="POST" novalidate class="needs-validation">
      <div class="mt-3 mb-3">
        <label for="Rating" class="form-label">Rating</label>
        <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
      </div>
      <div>
        <label for="comment" class="form-label">Comment</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="8" class="form-control" required></textarea>
      </div>
      <button class="btn btn-primary mb-2 mt-3 edit">Submit</button>
    </form>
  
    <h4><b>All Reviews</b></h4>
    <div class="row">
      <% for (let review of listings.review) { %>
        <div class="card col-5 ms-3 mt-3 mb-3">
          <div class="card-body">
            <h5 class="card-title">joe Boy</h5>
            <p class="card-text">Comment: <%= review.comment %></p>
            <p class="card-text">Rating: <%= review.rating %>/5</p>
            <form class="mb-3" method="POST" action="/listings/<%= listings.id %>/reviews/<%= review.id %>?_method=DELETE">
              <button class="btn btn-primary">Delete</button>
            </form>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
